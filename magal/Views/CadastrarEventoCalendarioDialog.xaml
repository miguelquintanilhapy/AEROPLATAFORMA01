<Window x:Class="magal.Views.CadastrarEventoCalendarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Novo Evento"
        Height="580" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F0F4FA">

    <Window.Resources>
        <SolidColorBrush x:Key="AzulAero"     Color="#131C49"/>
        <SolidColorBrush x:Key="AeroBorder"   Color="#E2E8F0"/>
        <SolidColorBrush x:Key="AeroTextDark" Color="#334155"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AzulAero}"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                BorderBrush="{StaticResource AeroBorder}"
                                BorderThickness="1.5"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Height"                   Value="36"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="BorderBrush"              Value="{StaticResource AeroBorder}"/>
            <Setter Property="BorderThickness"          Value="1.5"/>
            <Setter Property="Background"               Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="Cursor"                   Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AzulAero}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="32,28">

        <TextBlock Text="Novo Evento"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource AzulAero}"
                   Margin="0,0,0,24"/>

        <TextBlock Text="DESCRIÇÃO" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtDescricao"
                 Style="{StaticResource InputStyle}"
                 Margin="0,0,0,14"/>

        <TextBlock Text="TIPO" Style="{StaticResource LabelStyle}"/>
        <ComboBox x:Name="ComboTipo"
                  Style="{StaticResource ComboStyle}"
                  Margin="0,0,0,14"
                  FontWeight="SemiBold">
            <ComboBoxItem Content="Feriado Nacional" IsSelected="True"/>
            <ComboBoxItem Content="Feriado Estadual/Municipal"/>
            <ComboBoxItem Content="Ponte"/>
            <ComboBoxItem Content="Férias Coletivas"/>
        </ComboBox>

        <TextBlock Text="DATA" Style="{StaticResource LabelStyle}"/>
        <DatePicker x:Name="DpData"
                    FontSize="13" FontWeight="SemiBold"
                    Foreground="{StaticResource AeroTextDark}"
                    BorderThickness="1.5" Padding="8,0" Height="40"
                    Cursor="Hand" VerticalContentAlignment="Center"
                    Language="pt-BR" Margin="0,0,0,14">
            <DatePicker.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Padding="{TemplateBinding Padding}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type DatePicker}">
                    <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DatePicker.Resources>
        </DatePicker>

        <TextBlock Text="DATA ORIGINAL (somente para substituições)"
                   Style="{StaticResource LabelStyle}"/>
        <DatePicker x:Name="DpDataOriginal"
                    FontSize="13" FontWeight="SemiBold"
                    Foreground="{StaticResource AeroTextDark}"
                    BorderThickness="1.5" Padding="8,0" Height="40"
                    Cursor="Hand" VerticalContentAlignment="Center"
                    Language="pt-BR" Margin="0,0,0,24">
            <DatePicker.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Padding="{TemplateBinding Padding}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type DatePicker}">
                    <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DatePicker.Resources>
        </DatePicker>

        <Button Content="SALVAR EVENTO"
                Style="{StaticResource PrimaryBtn}"
                Click="BtnSalvar_Click"/>

    </StackPanel>
</Window>