<Window x:Class="magal.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AERO - Login" 
        Height="1265" Width="1847"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=txtUsuario}">

    <Window.Resources>
        <SolidColorBrush x:Key="AeroPrimary"    Color="#1E3A8A"/>
        <SolidColorBrush x:Key="AeroAccent"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroTextDark"   Color="#0F172A"/>
        <SolidColorBrush x:Key="AeroTextMuted"  Color="#64748B"/>
        <SolidColorBrush x:Key="AeroBorder"     Color="#E2E8F0"/>
        <SolidColorBrush x:Key="AeroBackground" Color="#F0F4FA"/>
        <SolidColorBrush x:Key="AzulAero" Color="#131C49"/>
        <SolidColorBrush x:Key="CinzaAero" Color="#ACACAC"/>
        <SolidColorBrush x:Key="AeroDanger" Color="#EF4444"/>

        <Style x:Key="AeroInput" TargetType="Control">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border x:Name="Bd" 
                                CornerRadius="8" 
                                BorderThickness="1.5" 
                                BorderBrush="{StaticResource AeroBorder}" 
                                Background="White">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AeroAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" Background="{StaticResource AeroBackground}" Margin="10,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="160,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1214*"/>
                <RowDefinition Height="35*"/>
            </Grid.RowDefinitions>
            <Image Source="/Imagens/2026 2.png" Stretch="UniformToFill" Margin="-171,0,-403,0" Grid.RowSpan="2"/>
        </Grid>

        <Grid Background="White" Margin="34,0,0,0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.5*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Viewbox Margin="60,-3,60,0" VerticalAlignment="Top" Height="692" Grid.RowSpan="2">
                <Image Source="/Imagens/AERO_CONCEPTS_2.png" Stretch="Uniform" Height="4232" Width="4247"/>
            </Viewbox>

            <Border Grid.Row="1" Width="419" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,90,0,0">
                <StackPanel>
                    <TextBlock Text="BEM-VINDO" FontSize="28" FontWeight="Bold" 
                               Foreground="{StaticResource AzulAero}" HorizontalAlignment="Center"/>

                    <TextBlock Text="Acesse o sistema com suas credenciais" FontSize="15" FontWeight="Bold" 
                               Foreground="{StaticResource CinzaAero}" Margin="0,5,0,35" HorizontalAlignment="Center"/>

                    <TextBlock Text="E-MAIL" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AeroTextMuted}" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtUsuario" Style="{StaticResource AeroInput}" Margin="0,0,0,20"/>

                    <TextBlock Text="SENHA" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AeroTextMuted}" Margin="0,0,0,8"/>
                    <Grid>
                        <PasswordBox x:Name="txtSenha" Style="{StaticResource AeroInput}" Padding="12,0,45,0"
                 PreviewKeyDown="TxtSenha_PreviewKeyDown" PreviewKeyUp="TxtSenha_PreviewKeyUp" GotFocus="TxtSenha_GotFocus"/>

                        <TextBox x:Name="txtSenhaVisivel" Style="{StaticResource AeroInput}" Padding="12,0,45,0" Visibility="Collapsed"/>

                        <Button x:Name="btnMostrarSenha" Width="30" Height="30" HorizontalAlignment="Right" 
            Margin="0,0,10,0" Cursor="Hand"
            PreviewMouseDown="BtnMostrarSenha_PreviewMouseDown" PreviewMouseUp="BtnMostrarSenha_PreviewMouseUp">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock x:Name="iconOlho" Text="👁️" FontSize="16" Foreground="{StaticResource AeroTextMuted}"/>
                        </Button>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0" x:Name="pnlCapsWarning" Visibility="Collapsed">
                        <TextBlock Text="⚠️" Margin="0,0,5,0"/>
                        <TextBlock Text="Caps Lock ativado" FontSize="12" Foreground= "#EF4444" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button x:Name="LoginButton" 
                            Content="ENTRAR NO SISTEMA" 
                            Height="55" Margin="0,40,0,0"
                            Background="{StaticResource AzulAero}" 
                            Foreground="White" 
                            FontSize="14" FontWeight="Bold" 
                            Cursor="Hand" Click="LoginButton_Click" IsDefault="True">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1e40af"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="Esqueci minha senha"
                               FontSize="13" Foreground="{StaticResource AeroAccent}" Margin="0,25,0,0"
                               HorizontalAlignment="Center" Cursor="Hand"
                               TextDecorations="Underline" MouseLeftButtonDown="SenhaButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>